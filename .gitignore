# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Migrations com dados sensíveis
migration_*.sql

# Backups de imagens/vídeo originais (gerados por scripts/compress-images.mjs)
public/*.original.*

# Artifacts gerados por scripts/importar-documentos.ts
skipped.csv
errors.csv
import-log.txt

# Artifacts gerados por scripts/importar-pagamentos-2026.ts
pagamentos-unmatched.csv
pagamentos-errors.csv
